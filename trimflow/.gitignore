# ===================================================================
# BarberFlow - Backend (.gitignore)
# Protegge secret, file locali e build artifacts
# ===================================================================

# --- Environment & Secrets (CRITICO) ---
.env
*.env
.env.local
.env.production
application-prod.properties
!application.properties.example

# --- Build & Compilation ---
HELP.md
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# --- IDE ---
### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### IntelliJ IDEA ###
.idea
*.iws
*.iml
*.ipr
out/

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

### VS Code ###
.vscode/

# --- Logs & Temp ---
*.log
logs/
temp/
tmp/
*.tmp
*.bak
*.swp
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Database & Data (se locale) ---
*.sql
*.dump
!src/main/resources/db/migration/*.sql  # ← Mantieni le migrazioni Flyway!

# --- Secrets & Keys ---
*.pem
*.key
*.p12
*.jks
secrets/
keystore/

# --- Docker (opzionale, se non vuoi committare config locali) ---
docker-compose.override.yml
!.dockerignore