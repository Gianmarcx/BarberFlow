# BarberFlow - Variabili d'ambiente opzionali
# Copia questo file in .env se vuoi personalizzare la configurazione

# Server
# SERVER_PORT=8081

# Database (lascia vuoto per sviluppo locale senza password)
# DB_URL=jdbc:mariadb://127.0.0.1:3306/barberflow
# DB_USERNAME=root
# DB_PASSWORD=

# JWT - In produzione, genera una chiave casuale di 32+ caratteri
# Esempio: openssl rand -base64 32
# JWT_SECRET=la-tua-chiave-segreta-qui

# Logging
# LOG_LEVEL_ROOT=INFO
# LOG_LEVEL_APP=DEBUG

# Flyway
# FLYWAY_ENABLED=true